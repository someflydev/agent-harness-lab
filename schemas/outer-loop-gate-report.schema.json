{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Outer Loop Gate Report",
  "type": "object",
  "required": [
    "ok",
    "status",
    "prompt_id",
    "changed_files",
    "validation_commands",
    "validation_outcomes",
    "ahl_checks",
    "completion_audit",
    "next_prompt_readiness",
    "handoff",
    "commit_plan",
    "decision",
    "warnings",
    "problems"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "schema": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "pass-with-warnings",
        "blocked",
        "failed-validation",
        "needs-human-review",
        "driver-failed",
        "unsafe-git-state"
      ]
    },
    "prompt_id": { "type": "string", "pattern": "^PROMPT_[0-9]{2}$" },
    "prompt_file": { "type": "string" },
    "prompt_file_exists": { "type": "boolean" },
    "plan": { "type": "object" },
    "git": { "type": "object" },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_commands": {
      "type": "object",
      "required": ["source", "commands"],
      "properties": {
        "source": { "type": "string" },
        "commands": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "validation_outcomes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "ahl_checks": {
      "type": "array",
      "items": { "type": "object" }
    },
    "completion_audit": { "type": "object" },
    "next_prompt_readiness": { "type": "object" },
    "handoff": { "type": "object" },
    "commit_plan": { "type": "object" },
    "decision": {
      "type": "string",
      "enum": ["continue", "continue-with-review", "stop", "stop-for-human-review"]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "problems": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
