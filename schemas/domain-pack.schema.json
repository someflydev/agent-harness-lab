{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/domain-pack.schema.json",
  "title": "Domain Pack Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "name",
    "status",
    "purpose",
    "entrypoint",
    "files",
    "optional",
    "core_doctrine_changes"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^_template$|^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "template",
        "example",
        "draft",
        "active",
        "retired"
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "optional": {
      "const": true
    },
    "core_doctrine_changes": {
      "const": false
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "command": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
