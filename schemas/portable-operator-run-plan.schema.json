{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portable Operator Run Range Plan",
  "type": "object",
  "required": [
    "ok",
    "schema",
    "plan_id",
    "created_at",
    "mode",
    "dry_run",
    "read_only",
    "project",
    "requested_range",
    "prompt_ids",
    "steps",
    "next_prompt",
    "restart_state",
    "safety_notes",
    "problems"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "schema": { "type": "string" },
    "plan_id": { "type": "string" },
    "created_at": { "type": "string" },
    "mode": { "type": "string", "const": "dry-run" },
    "dry_run": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "project": {
      "type": "object",
      "required": ["root", "prompt_dir", "prompt_dir_exists", "git"]
    },
    "configuration": { "type": "object" },
    "requested_range": { "type": "object" },
    "prompt_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PROMPT_[0-9]{2}$" }
    },
    "missing_prompt_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PROMPT_[0-9]{2}$" }
    },
    "malformed_prompt_filenames": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prompt_id", "path", "exists", "phase_order", "phases", "fresh_session_boundary"],
        "properties": {
          "prompt_id": { "type": "string", "pattern": "^PROMPT_[0-9]{2}$" },
          "path": { "type": "string" },
          "exists": { "type": "boolean" },
          "phase_order": {
            "type": "array",
            "items": { "type": "string" }
          },
          "phases": {
            "type": "array",
            "items": { "type": "object" }
          },
          "fresh_session_boundary": { "type": "string" }
        }
      }
    },
    "planned_artifact": { "type": ["string", "null"] },
    "next_prompt": { "type": ["string", "null"] },
    "stop_reason": { "type": ["string", "null"] },
    "restart_state": { "type": "object" },
    "safety_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "problems": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
