{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-harness-lab/run-record.schema.json",
  "title": "Run Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prompt_id",
    "prompt_batch_id",
    "run_id",
    "assistant_tool",
    "permission_posture",
    "started_at",
    "ended_at",
    "changed_files",
    "changed_directories",
    "docs_changed",
    "tests_changed",
    "validation_commands",
    "completion_audit_status",
    "next_prompt_ready",
    "readiness_blockers",
    "handoff_created",
    "follow_up_fix_required",
    "reusable_pattern_observations",
    "associated_commit_hashes"
  ],
  "properties": {
    "prompt_id": {
      "type": "string",
      "pattern": "^PROMPT_[0-9]{2}$"
    },
    "prompt_batch_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "assistant_tool": {
      "type": "string",
      "minLength": 1
    },
    "permission_posture": {
      "type": "string",
      "enum": ["read-only", "workspace-write", "manual-required"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_directories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs_changed": {
      "type": "boolean"
    },
    "tests_changed": {
      "type": "boolean"
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status", "exit_code", "summary"],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "exit_code": {
            "type": ["integer", "null"]
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "completion_audit_status": {
      "type": "string",
      "enum": ["not_started", "passed", "warning", "failed", "skipped"]
    },
    "next_prompt_ready": {
      "type": ["boolean", "null"]
    },
    "readiness_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff_created": {
      "type": "boolean"
    },
    "follow_up_fix_required": {
      "type": "boolean"
    },
    "reusable_pattern_observations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "associated_commit_hashes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{7,40}$"
      }
    }
  }
}
