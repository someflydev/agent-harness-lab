{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-harness-lab/readiness-report.schema.json",
  "title": "Readiness Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "active_prompt",
    "next_prompt",
    "owner_role",
    "prerequisites_checked",
    "readiness_label",
    "blockers",
    "warnings",
    "evidence",
    "next_step"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "active_prompt": {
      "type": "string",
      "pattern": "^PROMPT_[0-9]{2}$"
    },
    "next_prompt": {
      "type": "string",
      "pattern": "^PROMPT_[0-9]{2}$"
    },
    "owner_role": {
      "type": "string"
    },
    "prerequisites_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readiness_label": {
      "type": "string",
      "enum": ["ready", "risky", "blocked"]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cheap_bridge_fixes_applied": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "files_to_inspect_first": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "handoff_recommendation": {
      "type": "string"
    },
    "next_step": {
      "type": "string"
    }
  }
}
