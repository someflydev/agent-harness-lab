{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://somefly.dev/agent-harness-lab/schemas/lane-status.schema.json",
  "title": "Lane Status",
  "type": "object",
  "required": [
    "lane_id",
    "simulation",
    "state",
    "roles",
    "artifacts",
    "current_step",
    "stop_escalation"
  ],
  "properties": {
    "lane_id": {
      "type": "string",
      "minLength": 1
    },
    "simulation": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["pending", "active", "review", "audited", "blocked", "escalated", "done"]
    },
    "roles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "current_step": {
      "type": "string",
      "minLength": 1
    },
    "stop_escalation": {
      "type": "object",
      "required": ["needed"],
      "properties": {
        "needed": {
          "type": "boolean"
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_needed": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

