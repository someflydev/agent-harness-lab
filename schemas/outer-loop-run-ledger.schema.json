{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Outer Loop Run Ledger",
  "type": "object",
  "required": [
    "ok",
    "status",
    "run_id",
    "plan_id",
    "mode",
    "driver",
    "steps",
    "problems"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "schema": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "driver-failed",
        "failed-validation",
        "unsafe-git-state",
        "unexpected-plan-mutation",
        "interrupted",
        "driver-timeout",
        "driver-rate-limit",
        "driver-auth-failure",
        "prompt-execution-failed",
        "validation-failed",
        "completion-audit-incomplete",
        "next-prompt-readiness-blocked",
        "unexpected-changed-files",
        "commit-plan-refused",
        "user-interrupted",
        "unknown-failure",
        "running"
      ]
    },
    "run_id": { "type": ["string", "null"] },
    "plan_id": { "type": ["string", "null"] },
    "mode": { "type": "string", "enum": ["dry-run", "live"] },
    "execute": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "started_at": { "type": "string" },
    "ended_at": { "type": ["string", "null"] },
    "plan_artifact": { "type": "string" },
    "plan_sha256": { "type": "string" },
    "driver": { "type": ["object", "null"] },
    "model": { "type": ["string", "null"] },
    "reasoning": { "type": ["string", "null"] },
    "permission_posture": { "type": ["string", "null"] },
    "command_metadata": { "type": "object" },
    "validation_results": { "type": "array", "items": { "type": "object" } },
    "gate_results": { "type": "array", "items": { "type": "object" } },
    "commit_plan": { "type": ["object", "null"] },
    "commit_hashes": { "type": "array", "items": { "type": "string" } },
    "resume_pointer": { "type": "object" },
    "stop_reason": { "type": ["string", "null"] },
    "recovery_recommendation": { "type": ["string", "null"] },
    "max_prompts": { "type": ["integer", "null"] },
    "timeout_seconds": { "type": "integer" },
    "transcript_capture_policy": { "type": "object" },
    "steps": {
      "type": "array",
      "items": { "type": "object" }
    },
    "artifact": { "type": "string" },
    "problems": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
